{
  "schedules": {
    "hourly": {
      "modules": ["security", "network", "management", "identity", "hardware"],
      "args": "--storage-mode quick",
      "interval_minutes": 60,
      "description": "Security/identity monitoring + quick hardware snapshot (drive totals only)"
    },
    "every4hours": {
      "modules": ["applications", "inventory", "system", "peripherals"],
      "interval_minutes": 240,
      "description": "Modules that change moderately - software, device info, and peripheral devices"
    },
    "daily": {
      "modules": ["hardware"],
      "args": "--storage-mode deep",
      "interval_minutes": 1440,
      "description": "Full hardware deep-scan including directory-level storage analysis"
    },
    "all": {
      "modules": ["security", "network", "applications", "inventory", "system", "hardware", "management", "peripherals", "identity"],
      "args": "--storage-mode deep",
      "interval_minutes": 720,
      "description": "Run all available modules (except installs) for comprehensive data collection"
    }
  },
  "task_settings": {
    "start_boundary": "2025-01-01T09:00:00",
    "execution_time_limit": "PT30M",
    "restart_count": 3,
    "restart_interval": "PT5M",
    "run_only_if_network_available": true,
    "wake_to_run": false,
    "allow_start_on_demand": true,
    "stop_if_going_on_batteries": false,
    "disallow_start_if_on_batteries": false
  },
  "version": "1.1.0",
  "updated": "2025-08-10T00:00:00Z"
}
