<Page
    x:Class="ReportMate.App.Views.LogsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    NavigationCacheMode="Required">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ═══ Left Panel: Log File List ═══ -->
        <Border Grid.Column="0" Margin="24,16,0,24"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1" CornerRadius="8" Padding="0">
            <Grid RowSpacing="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Header -->
                <StackPanel Grid.Row="0" Padding="16,12" Spacing="8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE9D5;" FontSize="16"
                                  Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                        <TextBlock Text="Log Sessions" Style="{StaticResource BodyStrongTextBlockStyle}" />
                    </StackPanel>
                    <TextBlock x:Name="LogCountLabel" Text=""
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>

                <!-- Log List -->
                <ListView x:Name="LogListView" Grid.Row="1"
                          SelectionChanged="LogListView_SelectionChanged">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Padding="4,6" Spacing="2">
                                <TextBlock Text="{Binding FileName}"
                                           Style="{StaticResource BodyTextBlockStyle}"
                                           TextTrimming="CharacterEllipsis" />
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="{Binding Modified, Mode=OneTime}"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <TextBlock Text="{Binding SizeLabel}"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <!-- Toolbar -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="4" Padding="12,8"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="0,1,0,0">
                    <Button ToolTipService.ToolTip="Open in Notepad" Click="OpenInEditor_Click" Padding="8,6">
                        <FontIcon Glyph="&#xE70F;" FontSize="14" />
                    </Button>
                    <Button ToolTipService.ToolTip="Open Log Folder" Click="OpenFolder_Click" Padding="8,6">
                        <FontIcon Glyph="&#xE838;" FontSize="14" />
                    </Button>
                    <Button ToolTipService.ToolTip="Refresh" Click="Refresh_Click" Padding="8,6">
                        <FontIcon Glyph="&#xE72C;" FontSize="14" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ Right Panel: Log Content Viewer ═══ -->
        <Grid Grid.Column="1" Margin="12,16,24,24" RowSpacing="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Filter -->
            <TextBox x:Name="FilterBox" Grid.Row="0"
                     PlaceholderText="Filter log lines..."
                     TextChanged="FilterBox_TextChanged" />

            <!-- Content -->
            <Border Grid.Row="1"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <RichTextBlock x:Name="LogContent"
                                   FontFamily="Cascadia Mono, Consolas, Courier New"
                                   FontSize="12" TextWrapping="Wrap"
                                   IsTextSelectionEnabled="True" />
                </ScrollViewer>
            </Border>

            <!-- Empty State (overlays content area) -->
            <StackPanel x:Name="EmptyState" Grid.Row="1"
                        VerticalAlignment="Center" HorizontalAlignment="Center"
                        Spacing="8" Visibility="Collapsed">
                <FontIcon Glyph="&#xE9D5;" FontSize="48"
                          Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                          HorizontalAlignment="Center" />
                <TextBlock Text="No log files found"
                           Style="{StaticResource SubtitleTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           HorizontalAlignment="Center" />
                <TextBlock Text="Run a collection to generate log output."
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Grid>
    </Grid>
</Page>
