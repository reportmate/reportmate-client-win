<Page
    x:Class="ReportMate.App.Views.RunPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    NavigationCacheMode="Required">

    <Grid RowSpacing="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ═══ Run Control Bar ═══ -->
        <Grid Grid.Row="0" Padding="24,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Run / Stop Button -->
            <Button x:Name="RunButton" Grid.Column="0" Click="RunButton_Click" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon x:Name="RunIcon" Glyph="&#xE768;" FontSize="16" />
                    <TextBlock x:Name="RunText" Text="Run ReportMate" />
                </StackPanel>
            </Button>

            <!-- Debug + Clear -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12" Margin="12,0,0,0" VerticalAlignment="Center">
                <CheckBox x:Name="DebugToggle" Content="Debug" Checked="DebugToggle_Changed"
                          Unchecked="DebugToggle_Changed" />
                <Button x:Name="ClearButton" Content="Clear" Click="ClearButton_Click"
                        Visibility="Collapsed" />
            </StackPanel>

            <!-- Right-aligned status -->
            <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <!-- Running indicator -->
                <ProgressRing x:Name="RunningProgress" IsActive="False" Width="20" Height="20" />
                <TextBlock x:Name="RunningLabel" Text="Running..."
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           VerticalAlignment="Center" Visibility="Collapsed" />

                <!-- Status indicator -->
                <StackPanel x:Name="StatusPanel" Orientation="Horizontal" Spacing="4" Visibility="Collapsed">
                    <FontIcon x:Name="StatusIcon" Glyph="&#xE73E;" FontSize="16" />
                    <TextBlock x:Name="StatusText" Text="" VerticalAlignment="Center" />
                </StackPanel>
            </StackPanel>
        </Grid>

        <!-- ═══ Module Selector ═══ -->
        <Border Grid.Row="1" Margin="24,0,24,0"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1" CornerRadius="8" Padding="16">
            <StackPanel Spacing="8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10">
                        <FontIcon Glyph="&#xE74C;" FontSize="16"
                                  Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" VerticalAlignment="Center" />
                        <TextBlock Text="Modules" Style="{StaticResource BodyStrongTextBlockStyle}" VerticalAlignment="Center" />
                        <TextBlock x:Name="ModuleSummaryLabel" Text="All modules"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   VerticalAlignment="Center" Margin="8,0,0,0" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                        <Button Content="Select All" Click="SelectAll_Click" Padding="8,4" />
                        <Button Content="Deselect All" Click="DeselectAll_Click" Padding="8,4" />
                    </StackPanel>
                </Grid>

                <!-- Module checkboxes in a wrapping grid -->
                <ItemsRepeater x:Name="ModuleRepeater">
                    <ItemsRepeater.Layout>
                        <UniformGridLayout MinItemWidth="180" MinItemHeight="32"
                                           MinColumnSpacing="4" MinRowSpacing="2"
                                           ItemsStretch="Fill" />
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate>
                            <CheckBox Content="{Binding DisplayName}"
                                      IsChecked="{Binding IsSelected, Mode=TwoWay}" />
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </StackPanel>
        </Border>

        <!-- ═══ Progress Bar ═══ -->
        <StackPanel x:Name="ProgressPanel" Grid.Row="2" Padding="24,12" Spacing="4" Visibility="Collapsed">
            <ProgressBar x:Name="StepProgress" IsIndeterminate="True" />
            <Grid>
                <TextBlock x:Name="StepItemLabel" Text="Initializing..."
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <TextBlock x:Name="StepCountLabel" Text=""
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           HorizontalAlignment="Right" />
            </Grid>
        </StackPanel>

        <!-- ═══ Result Banner ═══ -->
        <InfoBar x:Name="ResultBanner" Grid.Row="3" IsOpen="False" Margin="24,0" />

        <!-- ═══ Console Output ═══ -->
        <Border Grid.Row="4" Margin="24,8,24,24" Padding="16"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1" CornerRadius="8">
            <ScrollViewer x:Name="ConsoleScroller" VerticalScrollBarVisibility="Auto">
                <RichTextBlock x:Name="ConsoleOutput"
                               FontFamily="Cascadia Mono, Consolas, Courier New"
                               FontSize="12" TextWrapping="Wrap"
                               IsTextSelectionEnabled="True" />
            </ScrollViewer>
        </Border>
    </Grid>
</Page>
